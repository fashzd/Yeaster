# ─────────────────────────────────────────────────────────────────────────────
# Yeaster environment.  Copy to `.env` and fill in.  Yeaster-owned knobs use the
# YST_ prefix; everything else authenticates to a third-party service (including
# the agent's wallet, via the TWAK keychain).
# ─────────────────────────────────────────────────────────────────────────────

# ── Market data: CoinMarketCap ───────────────────────────────────────────────
CMC_API_KEY=
CMC_MCP_API_KEY=
# CMC_SKILL_HUB_URL=https://mcp.coinmarketcap.com/skill-hub/stream

# ── Language model backbone ──────────────────────────────────────────────────
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
YST_LLM_PROVIDER=openai          # openai | anthropic
# YST_LLM_MODEL=gpt-5-mini       # override; else provider default
YST_COMMIT_STYLE=aggressive      # aggressive | disciplined

# ── Execution + wallet: Trust Wallet AgentKit (SAME wallet as before) ─────────
TWAK_CLI_BIN=twak
TWAK_MCP_URL=
TWAK_MCP_API_KEY=
TWAK_REST_URL=
TWAK_REST_API_KEY=
TWAK_ACCESS_ID=
TWAK_HMAC_SECRET=
TW_ACCESS_ID=
TW_HMAC_SECRET=
TWAK_WALLET_PASSWORD=
BNBAGENT_WALLET_PASSWORD=
BSC_TESTNET_RPC_URL=
BSC_TESTNET_WALLET_ADDRESS=
BSC_TESTNET_PRIVATE_KEY=
# YST_AGENT_WALLET=              # optional address override
# YST_PORTFOLIO_CHAIN=bsc       # chain the live wallet balance is read from

# ── Brain / pipeline knobs ───────────────────────────────────────────────────
YST_USE_SKILLS=1
YST_SKILLS_BACKEND=auto          # auto | mcp | rest | mock
YST_COMMIT_ARM=llm_lead          # commit policy arm
YST_EXIT_MODE=native             # native | emulated
YST_GRADE_CAP=12
YST_SNAPSHOT_TOPN=150
YST_WIDE_SNAPSHOT=1
YST_GUARD_WIDE_ALLOWLIST=1
YST_HIST_REFRESH_SECONDS=21600
YST_WHALE_CONCENTRATION_LIMIT_PCT=30.0

# ── Safety gates ─────────────────────────────────────────────────────────────
YST_APPROVAL_SECRET=             # set a real secret in production
YST_TRADE_CHAIN_ID=56            # 97 testnet / 56 mainnet
# Real mainnet execution requires BOTH of the following:
YST_MAINNET=0
YST_MAINNET_CONFIRM=             # must equal I-UNDERSTAND-LIVE-FUNDS to unlock

# x402 micropayments (TWAK hackathon)
YST_X402=0
YST_X402_SECRET=
